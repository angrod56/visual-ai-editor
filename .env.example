# ─── Supabase ───────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key — only used on the server, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Anthropic Claude ────────────────────────────────────────────────────────
# Found in: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── OpenAI (Whisper transcription + DALL-E 3) ──────────────────────────────
# Found in: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ─── Google Imagen 3 (image generation) ─────────────────────────────────────
# Found in: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-google-ai-studio-key-here

# ─── FFmpeg (optional override) ─────────────────────────────────────────────
# Leave blank to use @ffmpeg-installer/ffmpeg bundled binary
# FFMPEG_PATH=/usr/local/bin/ffmpeg

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
